# Database
DATABASE_URL=postgresql://user:password@localhost:5432/reservation_db
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/reservation_test_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# SMTP (개발: Mailtrap / 프로덕션: Gmail)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
SMTP_FROM=noreply@reservation.example.com

# 공공데이터 포털 공휴일 API
PUBLIC_HOLIDAY_API_KEY=your_api_key_here

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_WS_URL=http://localhost:4000
NEXT_PUBLIC_USE_MOCK=true
