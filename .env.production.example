# ===== 프로덕션 환경변수 템플릿 =====
# 이 파일을 .env.production으로 복사 후 실제 값을 입력하세요.

# PostgreSQL
POSTGRES_USER=reservation_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=reservation_db

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# JWT (반드시 랜덤 문자열로 변경)
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_64CHARS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_64CHARS

# SMTP (Gmail 예시)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@your-domain.com

# 공공데이터 포털 공휴일 API
PUBLIC_HOLIDAY_API_KEY=your_api_key

# Frontend
NEXT_PUBLIC_API_URL=https://your-domain.com/api
